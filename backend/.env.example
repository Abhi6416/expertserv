# ============================================================
# ExpertServ Solution - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit the real .env file to version control
# ============================================================

# ---- SERVER ----
PORT=5000
NODE_ENV=development

# ---- MONGODB ----
# 👇 Replace with your MongoDB Atlas connection string or local URI
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/expertserv?retryWrites=true&w=majority

# ---- JWT AUTH (Admin Dashboard) ----
# 👇 Replace with a strong random string (e.g. openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# ---- ADMIN CREDENTIALS ----
# 👇 Set your admin username and password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# ---- NODEMAILER (Email Notifications) ----
# 👇 Use Gmail App Password (not your actual Gmail password)
# Enable 2FA on Gmail → Generate App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM=ExpertServ Solution <your_email@gmail.com>
EMAIL_TO=leads@expertservsolution.com

# ---- TWILIO (WhatsApp Notifications) ----
# 👇 Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Twilio sandbox WhatsApp number (or approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# 👇 Your WhatsApp number to receive lead notifications
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ---- GOOGLE reCAPTCHA ----
# 👇 Get from https://www.google.com/recaptcha/admin/create
# Use reCAPTCHA v2 (I'm not a robot)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ---- FRONTEND URL (for CORS) ----
FRONTEND_URL=http://localhost:3000
